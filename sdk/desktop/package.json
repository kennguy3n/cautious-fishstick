{
  "name": "@shieldnet360/access-extension",
  "version": "0.1.0",
  "description": "ShieldNet 360 Access Platform — Electron IPC contract for desktop host apps. REST-only; no on-device inference.",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/access-ipc.js",
  "types": "dist/access-ipc.d.ts",
  "exports": {
    ".": {
      "types": "./dist/access-ipc.d.ts",
      "default": "./dist/access-ipc.js"
    },
    "./main-handler": {
      "types": "./dist/main-handler.d.ts",
      "default": "./dist/main-handler.js"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "default": "./dist/preload.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json --noEmit && echo \"sdk/desktop: typecheck passed\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  },
  "publishConfig": {
    "registry": "https://registry.internal.shieldnet360.example/"
  }
}
