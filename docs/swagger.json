    "/pam/leases/{id}/approve": {
      "post": {
        "summary": "Approve a pending PAM lease",
        "description": "Body requires workspace_id; the service layer enforces the workspace filter on the lookup.",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required or FSM rejection"
          },
          "404": {
            "description": "Lease not found in workspace"
          }
        }
      }
    },
    "/pam/leases/{id}/revoke": {
      "post": {
        "summary": "Revoke an active or pending PAM lease",
        "description": "Body requires workspace_id; cross-tenant revocation is blocked at the service layer.",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
