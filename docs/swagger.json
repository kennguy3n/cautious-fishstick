{
  "openapi": "3.0.0",
  "info": {
    "title": "ShieldNet 360 Access Platform API",
    "description": "HTTP surface for the ZTNA access platform (PHASES.md §11 + ARCHITECTURE.md §2). Covers access requests, reviews, grants, policy drafting / simulation, AI explain / suggest, and inbound SCIM (auto-sync users).\n\nThis spec is regenerated by `scripts/generate-swagger.sh` whenever a handler-level change ships (cross-cutting criterion in docs/PHASES.md).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin server. The access API is served by cmd/ztna-api."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "description": "Returns 200 OK without touching the DB or AI agent.",
        "tags": ["meta"],
        "responses": {
          "200": {
            "description": "Service alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "status": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "/access/requests": {
      "post": {
        "summary": "Create an access request",
        "tags": ["access-requests"],
        "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } }
      },
      "get": {
        "summary": "List access requests",
        "tags": ["access-requests"],
        "parameters": [
          { "name": "workspace_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "state", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "400": { "description": "Validation error" } }
      }
    },
    "/access/requests/{id}/approve": {
      "post": {
        "summary": "Approve an access request",
        "tags": ["access-requests"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" }, "409": { "description": "FSM rejection" } }
      }
    },
    "/access/requests/{id}/deny": {
      "post": {
        "summary": "Deny an access request",
        "tags": ["access-requests"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" }, "409": { "description": "FSM rejection" } }
      }
    },
    "/access/requests/{id}/cancel": {
      "post": {
        "summary": "Cancel an access request",
        "tags": ["access-requests"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" }, "409": { "description": "FSM rejection" } }
      }
    },
    "/access/grants": {
      "get": {
        "summary": "List active access grants",
        "tags": ["access-grants"],
        "parameters": [
          { "name": "user_id", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "connector_id", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "400": { "description": "At least one filter required" } }
      }
    },
    "/access/reviews": {
      "post": {
        "summary": "Start an access review campaign",
        "tags": ["access-reviews"],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/access/reviews/{id}/decisions": {
      "post": {
        "summary": "Submit a campaign decision",
        "tags": ["access-reviews"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/access/reviews/{id}/close": {
      "post": {
        "summary": "Close an access review campaign",
        "tags": ["access-reviews"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/access/reviews/{id}/auto-revoke": {
      "post": {
        "summary": "Auto-revoke unreviewed grants for a campaign",
        "tags": ["access-reviews"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/access/reviews/{id}/metrics": {
      "get": {
        "summary": "Get campaign metrics",
        "tags": ["access-reviews"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/workspace/policy": {
      "post": {
        "summary": "Create a draft policy",
        "tags": ["policy"],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/workspace/policy/drafts": {
      "get": {
        "summary": "List draft policies",
        "tags": ["policy"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/workspace/policy/{id}": {
      "get": {
        "summary": "Get policy",
        "tags": ["policy"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/workspace/policy/{id}/simulate": {
      "post": {
        "summary": "Simulate a policy",
        "tags": ["policy"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/workspace/policy/{id}/promote": {
      "post": {
        "summary": "Promote a draft policy to active",
        "tags": ["policy"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/workspace/policy/test-access": {
      "post": {
        "summary": "Test policy against a hypothetical access",
        "tags": ["policy"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/access/explain": {
      "post": {
        "summary": "Explain an access decision via the AI agent",
        "tags": ["ai"],
        "responses": { "200": { "description": "OK" }, "503": { "description": "AI agent not configured" } }
      }
    },
    "/access/suggest": {
      "post": {
        "summary": "Suggest access remediation via the AI agent",
        "tags": ["ai"],
        "responses": { "200": { "description": "OK" }, "503": { "description": "AI agent not configured" } }
      }
    },
    "/scim/Users": {
      "post": {
        "summary": "Provision a SCIM user (joiner / mover)",
        "tags": ["scim"],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/scim/Users/{id}": {
      "delete": {
        "summary": "Deprovision a SCIM user (leaver)",
        "tags": ["scim"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "204": { "description": "No Content" }, "404": { "description": "Not found" } }
      }
    },
    "/swagger": {
      "get": {
        "summary": "Serve this OpenAPI 3.0 spec",
        "tags": ["meta"],
        "responses": {
          "200": {
            "description": "swagger.json",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    }
  }
}
