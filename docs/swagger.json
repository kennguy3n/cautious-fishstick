    "/access/reviews/{id}/decisions/bulk": {
      "post": {
        "summary": "Submit multiple campaign decisions in a single best-effort batch",
        "description": "Each entry in the decisions array is dispatched through the same SubmitDecision flow; failures on one entry do NOT short-circuit the remaining entries. Always returns 200 with a per-row results array and a summary roll-up (total / succeeded / failed). Envelope-level failures (missing decided_by, empty array, malformed JSON) return 4xx.",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK \u2014 per-row success/error in results array"
          },
          "400": {
            "description": "Validation failed"
          }
        }
      }
    },
