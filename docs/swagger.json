{
  "openapi": "3.0.0",
  "info": {
    "title": "ShieldNet 360 Access Platform API",
    "description": "HTTP surface for the ZTNA access platform (see docs/architecture.md). Covers access requests, reviews, grants, policy drafting / simulation, AI explain / suggest, and inbound SCIM (auto-sync users).\n\nThis spec is regenerated by `scripts/generate-swagger.sh` whenever a handler-level change ships.\n\n## Correlation headers\n\nEvery response \u2014 including health, metrics, and error envelopes \u2014 carries an `X-Request-ID` header set by `internal/handlers.RequestIDMiddleware`. Clients SHOULD echo an inbound `X-Request-ID` header to thread a caller-supplied correlation key; otherwise the server mints a UUIDv4. The same value is mirrored in the `request_id` field of every 4xx/5xx body (see `ErrorEnvelope`) so support tickets can be reconciled with a single key.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin server. The access API is served by cmd/ztna-api."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "description": "Returns 200 OK without touching the DB or AI agent.",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "Service alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
