          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/pam/secrets/{id}/reveal": {
      "post": {
        "summary": "Reveal a PAM secret (requires step-up MFA)",
        "description": "Returns the decrypted plaintext only after the MFA verifier accepts the assertion.",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Missing MFA assertion or workspace_id"
          },
          "403": {
            "description": "MFA assertion rejected"
          },
          "404": {
            "description": "Not found"
          },
          "503": {
            "description": "MFA verifier not configured"
          }
        }
      }
    },
    "/pam/secrets/{id}/rotate": {
      "post": {
        "summary": "Rotate a PAM secret (generate-encrypt-replace)",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/pam/secrets/{id}/history": {
      "get": {
        "summary": "Get rotation history for a PAM secret",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Not found in workspace"
          }
        }
      }
    },
    "/pam/leases": {
      "post": {
        "summary": "Request a JIT lease (creates an access request + pending lease)",
        "tags": [
          "pam-leases"
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      },
      "get": {
        "summary": "List PAM leases for a workspace",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "asset_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "active",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
