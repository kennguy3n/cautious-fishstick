        "summary": "Natural-language assistant \u2014 classifies a free-text query and dispatches to the matching AI skill",
        "description": "Routes a chat-style query to one of access_risk_assessment,\naccess_anomaly_detection, connector_setup_assistant, or\npolicy_recommendation (default). The request may supply an\nexplicit 'skill' override to bypass classification. Returns\nthe matched intent, the dispatched skill name, and the raw\nSkillResponse envelope. Skill names match the Python\naccess-ai-agent registry exactly.\n",
        "tags": [
          "ai"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "query required"
          },
          "502": {
            "description": "Upstream AI agent failure"
          },
          "503": {
            "description": "AI agent not configured"
          }
