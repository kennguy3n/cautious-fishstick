{
  "openapi": "3.0.0",
  "info": {
    "title": "ShieldNet 360 Access Platform API",
    "description": "HTTP surface for the ZTNA access platform (docs/internal/PHASES.md \u00a711 + docs/architecture.md \u00a72). Covers access requests, reviews, grants, policy drafting / simulation, AI explain / suggest, and inbound SCIM (auto-sync users).\n\nThis spec is regenerated by `scripts/generate-swagger.sh` whenever a handler-level change ships (cross-cutting criterion in docs/internal/PHASES.md).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin server. The access API is served by cmd/ztna-api."
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "description": "Returns 200 OK without touching the DB or AI agent.",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "Service alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/access/requests": {
      "post": {
        "summary": "Create an access request",
        "tags": [
          "access-requests"
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      },
      "get": {
        "summary": "List access requests",
        "tags": [
          "access-requests"
        ],
        "parameters": [
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/access/requests/{id}": {
      "get": {
        "summary": "Get an access request with its state-history audit trail",
        "tags": [
          "access-requests"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request + history"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/access/requests/{id}/approve": {
      "post": {
        "summary": "Approve an access request",
        "tags": [
          "access-requests"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "FSM rejection"
          }
        }
      }
    },
    "/access/requests/{id}/deny": {
      "post": {
        "summary": "Deny an access request",
        "tags": [
          "access-requests"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "FSM rejection"
          }
        }
      }
    },
    "/access/requests/{id}/cancel": {
      "post": {
        "summary": "Cancel an access request",
        "tags": [
          "access-requests"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          },
          "409": {
            "description": "FSM rejection"
          }
        }
      }
    },
    "/access/grants": {
      "get": {
        "summary": "List active access grants",
        "tags": [
          "access-grants"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connector_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "At least one filter required"
          }
        }
      }
    },
    "/access/grants/{id}/entitlements": {
      "get": {
        "summary": "List live app permissions for the user on the grant's connector",
        "tags": [
          "access-grants"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Grant not found"
          },
          "503": {
            "description": "App permission lookup not configured"
          }
        }
      }
    },
    "/access/connectors": {
      "get": {
        "summary": "List access connectors with last-sync timestamps and capability flags",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          }
        }
      },
      "post": {
        "summary": "Connect a new access connector \u2014 validates, probes, encrypts, persists, and enqueues an initial sync_identities job",
        "tags": [
          "access-connectors"
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation failed / unknown provider"
          },
          "409": {
            "description": "Duplicate connector for (workspace, provider, connector_type)"
          }
        }
      }
    },
    "/access/connectors/{id}": {
      "delete": {
        "summary": "Soft-delete an access connector \u2014 revokes active grants and deregisters SSO",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Connector not found"
          }
        }
      }
    },
    "/access/connectors/{id}/health": {
      "get": {
        "summary": "Get the operational health view of an access connector",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectorHealth"
                }
              }
            }
          },
          "404": {
            "description": "Connector not found"
          }
        }
      }
    },
    "/access/connectors/{id}/secret": {
      "put": {
        "summary": "Rotate connector credentials \u2014 re-validates, re-encrypts, and atomically updates the secrets column",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Validation failed"
          },
          "404": {
            "description": "Connector not found"
          }
        }
      }
    },
    "/access/connectors/{id}/sync": {
      "post": {
        "summary": "Trigger an immediate sync_identities job for the supplied connector",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Job enqueued"
          },
          "404": {
            "description": "Connector not found"
          }
        }
      }
    },
    "/access/connectors/catalogue": {
      "get": {
        "summary": "List the full process-global connector registry with per-workspace connection state",
        "description": "Returns one entry per registered provider with capability flags (sync_identities, sync_groups, sync_audit, scim_provision, sync_identities_delta) and, when the workspace already has a connection, the connector ID and status. Powers the Admin UI 'available integrations' marketplace.",
        "tags": [
          "access-connectors"
        ],
        "parameters": [
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          }
        }
      }
    },
    "/access/reviews": {
      "post": {
        "summary": "Start an access review campaign",
        "tags": [
          "access-reviews"
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/access/reviews/{id}/decisions": {
      "post": {
        "summary": "Submit a campaign decision",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/access/reviews/{id}/close": {
      "post": {
        "summary": "Close an access review campaign",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/access/reviews/{id}/decisions/bulk": {
      "post": {
        "summary": "Submit multiple campaign decisions in a single best-effort batch",
        "description": "Each entry in the decisions array is dispatched through the same SubmitDecision flow; failures on one entry do NOT short-circuit the remaining entries. Always returns 200 with a per-row results array and a summary roll-up (total / succeeded / failed). Envelope-level failures (missing decided_by, empty array, malformed JSON) return 4xx.",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK \u2014 per-row success/error in results array"
          },
          "400": {
            "description": "Validation failed"
          }
        }
      }
    },
    "/access/reviews/{id}/auto-revoke": {
      "post": {
        "summary": "Auto-revoke unreviewed grants for a campaign",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/access/reviews/{id}/metrics": {
      "get": {
        "summary": "Get campaign metrics",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/workspace/policy": {
      "post": {
        "summary": "Create a draft policy",
        "tags": [
          "policy"
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/workspace/policy/drafts": {
      "get": {
        "summary": "List draft policies",
        "tags": [
          "policy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/workspace/policy/{id}": {
      "get": {
        "summary": "Get policy",
        "tags": [
          "policy"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/workspace/policy/{id}/simulate": {
      "post": {
        "summary": "Simulate a policy",
        "tags": [
          "policy"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/workspace/policy/{id}/promote": {
      "post": {
        "summary": "Promote a draft policy to active",
        "tags": [
          "policy"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/workspace/policy/{id}/diff": {
      "get": {
        "summary": "Diff a draft policy against the workspace's current live state",
        "description": "Returns a structured before/after report comparing the live baseline (union of OTHER live policies in the workspace) against the projection of the draft. Requires a previously-simulated draft; otherwise returns 409 Conflict.",
        "tags": [
          "policy"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "409": {
            "description": "Draft has not been simulated or is no longer a draft"
          }
        }
      }
    },
    "/workspace/policy/test-access": {
      "post": {
        "summary": "Test policy against a hypothetical access",
        "tags": [
          "policy"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/access/explain": {
      "post": {
        "summary": "Explain an access decision via the AI agent",
        "tags": [
          "ai"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "503": {
            "description": "AI agent not configured"
          }
        }
      }
    },
    "/access/suggest": {
      "post": {
        "summary": "Suggest access remediation via the AI agent",
        "tags": [
          "ai"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "503": {
            "description": "AI agent not configured"
          }
        }
      }
    },
    "/access/assistant": {
      "post": {
        "summary": "Natural-language assistant \u2014 classifies a free-text query and dispatches to the matching AI skill",
        "description": "Routes a chat-style query to one of access_risk_assessment, access_anomaly_detection, connector_setup_assistant, or policy_recommendation (default). The request may supply an explicit 'skill' override to bypass classification. Returns the matched intent, the dispatched skill name, and the raw SkillResponse envelope. Skill names match the Python access-ai-agent registry exactly.",
        "tags": [
          "ai"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "query required"
          },
          "502": {
            "description": "Upstream AI agent failure"
          },
          "503": {
            "description": "AI agent not configured"
          }
        }
      }
    },
    "/scim/Users": {
      "post": {
        "summary": "Provision a SCIM user (joiner / mover)",
        "tags": [
          "scim"
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/scim/Users/{id}": {
      "delete": {
        "summary": "Deprovision a SCIM user (leaver)",
        "tags": [
          "scim"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "patch": {
        "summary": "Partially update a SCIM user (attribute change / role move)",
        "tags": [
          "scim"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/swagger": {
      "get": {
        "summary": "Serve this OpenAPI 3.0 spec",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "swagger.json",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus-format metrics",
        "description": "Returns request count/latency by route, connector sync duration, AI agent call latency, and queue depth in Prometheus text exposition format.",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "Prometheus text format",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/access/connectors/batch-status": {
      "post": {
        "summary": "Batch connector health lookup \u2014 avoids N+1 calls from the Admin UI connector list page",
        "description": "Accepts an array of connector IDs and returns each connector's health view in a single response. Per-entry errors (e.g. connector deleted) are inlined rather than aborting the whole request.",
        "tags": [
          "access-connectors"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error (empty array, oversized, malformed JSON)"
          }
        }
      }
    },
    "/access/reviews/{id}": {
      "patch": {
        "summary": "Patch an access review campaign (partial update)",
        "tags": [
          "access-reviews"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Campaign not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessRequest": {
        "type": "object",
        "description": "A user-submitted request to be granted access to a connector resource.",
        "properties": {
          "id": {
            "type": "string",
            "description": "ULID primary key"
          },
          "workspace_id": {
            "type": "string"
          },
          "requester_id": {
            "type": "string"
          },
          "connector_id": {
            "type": "string"
          },
          "resource_external_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "justification": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "pending_approval",
              "approved",
              "denied",
              "cancelled",
              "provisioned",
              "revoked",
              "expired"
            ]
          },
          "risk_score": {
            "type": "number",
            "format": "float"
          },
          "risk_label": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "requester_id",
          "connector_id",
          "state"
        ]
      },
      "AccessGrant": {
        "type": "object",
        "description": "An issued / revoked grant tying a user to a connector resource role.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "user_external_id": {
            "type": "string"
          },
          "connector_id": {
            "type": "string"
          },
          "resource_external_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "revoked",
              "expired"
            ]
          },
          "granted_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "user_external_id",
          "connector_id",
          "status"
        ]
      },
      "Policy": {
        "type": "object",
        "description": "Per-workspace access policy. Drafts have is_draft=true and is_active=false until promoted.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_draft": {
            "type": "boolean"
          },
          "is_active": {
            "type": "boolean"
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "name"
        ]
      },
      "AccessReview": {
        "type": "object",
        "description": "An access-review campaign covering a slice of active grants for periodic recertification.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "closed"
            ]
          },
          "frequency": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "closed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "name",
          "status"
        ]
      },
      "ConnectorHealth": {
        "type": "object",
        "description": "Operational health view of a single access connector.",
        "properties": {
          "connector_id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "connector_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "credential_expired_time": {
            "type": "string",
            "format": "date-time"
          },
          "last_sync_times": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Map of sync kind (identity/group/audit) to last-sync timestamp"
          },
          "stale_audit": {
            "type": "boolean"
          }
        },
        "required": [
          "connector_id",
          "provider",
          "status",
          "stale_audit"
        ]
      },
      "BatchStatusRequest": {
        "type": "object",
        "description": "POST body for /access/connectors/batch-status.",
        "properties": {
          "connector_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 200,
            "description": "Array of connector IDs to look up"
          }
        },
        "required": [
          "connector_ids"
        ]
      },
      "BatchStatusResponse": {
        "type": "object",
        "description": "Response envelope for /access/connectors/batch-status. Entries preserve the caller order (after dedup).",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchStatusEntry"
            }
          }
        },
        "required": [
          "entries"
        ]
      },
      "BatchStatusEntry": {
        "type": "object",
        "description": "Per-connector result. Exactly one of health, not_found, or error is populated.",
        "properties": {
          "connector_id": {
            "type": "string"
          },
          "not_found": {
            "type": "boolean"
          },
          "health": {
            "$ref": "#/components/schemas/ConnectorHealth"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "connector_id"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "description": "Canonical 4xx/5xx error envelope.",
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "code",
          "message"
        ]
      }
    }
  }
