            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error (empty array",
            "oversized": null,
            "malformed JSON)": null
          }
        }
      }
    },
