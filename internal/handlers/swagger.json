        "description": "Returns request count/latency by route, connector sync\nduration, AI agent call latency, and queue depth in\nPrometheus text exposition format.\n",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "Prometheus text format",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
