            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/pam/assets/{id}/accounts": {
      "post": {
        "summary": "Create a PAM account on an asset",
        "description": "Body requires `workspace_id` so the service layer can enforce\ntenant isolation on the asset lookup; passing a workspace that\ndoes not own the asset yields 404 even when the asset ULID is\nvalid.\n",
        "tags": [
          "pam-assets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error / workspace_id required"
          },
          "404": {
            "description": "Asset not found in workspace"
          }
        }
      },
      "get": {
        "summary": "List PAM accounts on an asset",
        "tags": [
          "pam-assets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/pam/secrets": {
      "post": {
        "summary": "Vault a PAM secret (encrypt-and-store)",
        "tags": [
          "pam-secrets"
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/pam/secrets/{id}": {
      "get": {
        "summary": "Get PAM secret metadata (never returns plaintext)",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/pam/secrets/{id}/reveal": {
      "post": {
        "summary": "Reveal a PAM secret (requires step-up MFA)",
        "description": "Returns the decrypted plaintext only after the MFA verifier\naccepts the assertion. Rate-limited by the workspace-scoped\ntoken bucket in `internal/handlers/rate_limit_middleware.go`\nas a second line of defence against MFA brute force.\n",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK \u2014 plaintext payload"
          },
          "400": {
            "description": "Missing MFA assertion / workspace_id"
          },
          "403": {
            "description": "MFA assertion rejected"
          },
          "404": {
            "description": "Not found"
          },
          "503": {
            "description": "MFA verifier not configured"
          }
        }
      }
    },
    "/pam/secrets/{id}/rotate": {
      "post": {
        "summary": "Rotate a PAM secret (generate-encrypt-replace)",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/pam/secrets/{id}/history": {
      "get": {
        "summary": "Get rotation history for a PAM secret",
        "tags": [
          "pam-secrets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Not found in workspace"
          }
        }
      }
    },
    "/pam/leases": {
      "post": {
        "summary": "Request a JIT lease (creates an access request + pending lease)",
        "tags": [
          "pam-leases"
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      },
      "get": {
        "summary": "List PAM leases for a workspace",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "workspace_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "asset_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "active",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          }
        }
      }
    },
    "/pam/leases/{id}/approve": {
      "post": {
        "summary": "Approve a pending PAM lease",
        "description": "Body requires `workspace_id`; the service layer enforces the\nworkspace filter on the lookup so a caller cannot approve a\nlease from another tenant even when the lease ULID is known.\n",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required / FSM rejection"
          },
          "404": {
            "description": "Lease not found in workspace"
          }
        }
      }
    },
    "/pam/leases/{id}/revoke": {
      "post": {
        "summary": "Revoke an active or pending PAM lease",
        "description": "Body requires `workspace_id`; same scoping contract as\n`/pam/leases/{id}/approve` \u2014 cross-tenant revocation is\nblocked at the service layer.\n",
        "tags": [
          "pam-leases"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "workspace_id required"
          },
          "404": {
            "description": "Lease not found in workspace"
          }
        }
      }
    },
    "/swagger": {
      "get": {
        "summary": "Serve this OpenAPI 3.0 spec",
        "tags": [
          "meta"
        ],
        "responses": {
          "200": {
            "description": "swagger.json"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessRequest": {
        "type": "object",
        "description": "A user-submitted request to be granted access to a connector resource.",
        "properties": {
          "id": {
            "type": "string",
            "description": "ULID primary key"
          },
          "workspace_id": {
            "type": "string"
          },
          "requester_id": {
            "type": "string"
          },
          "connector_id": {
            "type": "string"
          },
          "resource_external_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "justification": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "pending_approval",
              "approved",
              "denied",
              "cancelled",
              "provisioned",
              "revoked",
              "expired"
            ]
          },
          "risk_score": {
            "type": "number",
            "format": "float"
          },
          "risk_label": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "requester_id",
          "connector_id",
          "state"
        ]
      },
      "AccessGrant": {
        "type": "object",
        "description": "An issued / revoked grant tying a user to a connector resource role.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "user_external_id": {
            "type": "string"
          },
          "connector_id": {
            "type": "string"
          },
          "resource_external_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "revoked",
              "expired"
            ]
          },
          "granted_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "user_external_id",
          "connector_id",
          "status"
        ]
      },
      "Policy": {
        "type": "object",
        "description": "Per-workspace access policy. Drafts have is_draft=true and is_active=false until promoted.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_draft": {
            "type": "boolean"
          },
          "is_active": {
            "type": "boolean"
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "name"
        ]
      },
      "AccessReview": {
        "type": "object",
        "description": "An access-review campaign covering a slice of active grants for periodic recertification.",
        "properties": {
          "id": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "closed"
            ]
          },
          "frequency": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "closed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "workspace_id",
          "name",
          "status"
        ]
      },
      "ConnectorHealth": {
        "type": "object",
        "description": "Operational health view of a single access connector.",
        "properties": {
          "connector_id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "connector_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "credential_expired_time": {
            "type": "string",
            "format": "date-time"
          },
          "last_sync_times": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Map of sync kind (identity/group/audit) to last-sync timestamp"
          },
          "stale_audit": {
            "type": "boolean"
          }
        },
        "required": [
          "connector_id",
          "provider",
          "status",
          "stale_audit"
        ]
      },
      "BatchStatusRequest": {
        "type": "object",
        "description": "POST body for /access/connectors/batch-status.",
        "properties": {
          "connector_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 200,
            "description": "Array of connector IDs to look up"
          }
        },
        "required": [
          "connector_ids"
        ]
      },
      "BatchStatusResponse": {
        "type": "object",
        "description": "Response envelope for /access/connectors/batch-status. Entries preserve the caller order (after dedup).",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchStatusEntry"
            }
          }
        },
        "required": [
          "entries"
        ]
      },
      "BatchStatusEntry": {
        "type": "object",
        "description": "Per-connector result. Exactly one of health, not_found, or error is populated.",
        "properties": {
          "connector_id": {
            "type": "string"
          },
          "not_found": {
            "type": "boolean"
          },
          "health": {
            "$ref": "#/components/schemas/ConnectorHealth"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "connector_id"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "description": "Canonical 4xx/5xx error envelope.",
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string",
            "description": "Correlation key stamped by `internal/handlers.RequestIDMiddleware`;\nidentical to the `X-Request-ID` response header. Echo this value\nwhen filing a support ticket.\n"
          }
        },
        "required": [
          "error",
          "code",
          "message"
        ]
      }
    },
    "headers": {
      "X-Request-ID": {
        "description": "Correlation key for the request. Echoed back from a caller-supplied\n`X-Request-ID` (sanitised, capped at 128 bytes) or minted as a UUIDv4\nby `internal/handlers.RequestIDMiddleware`. Present on every response\nand mirrored in the `request_id` field of `ErrorEnvelope`.\n",
        "schema": {
          "type": "string"
        }
      }
    }
  }
}
